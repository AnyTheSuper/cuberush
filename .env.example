# Copy values from Supabase → Project Settings → API
# Set these in Vercel → Project → Settings → Environment Variables (not in git).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ_your_anon_public_key

# Public site URL for SEO meta tags, sitemap, and Open Graph (no trailing slash).
# GitHub Pages example: https://anythesuper.github.io/cuberush
VITE_SITE_URL=https://anythesuper.github.io/cuberush
